generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  super_admin
  user
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatarUrl String?
  role      SystemRole @default(user)
  isDeleted Boolean  @default(false)

  workspaces WorkspaceMember[]
  goals      Goal[] @relation("GoalOwner")
  activities GoalActivity[]
  notifications Notification[]

  announcements Announcement[]
  reactions     Reaction[]
  comments      Comment[]
  actionItems ActionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  accentColor String   @default("#3B82F6")

  members     WorkspaceMember[]
  goals       Goal[]

  announcements Announcement[]
  actionItems ActionItem[]
  invites WorkspaceInvite[]
  notifications Notification[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkspaceMember {
  id          String @id @default(uuid())

  userId      String
  workspaceId String

  role        WorkspaceRole @default(MEMBER)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

model WorkspaceInvite {
  id          String   @id @default(uuid())

  email       String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)

  invitedById String

  status      InviteStatus @default(PENDING)

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Notification {
  id          String   @id @default(uuid())

  userId      String
  workspaceId String

  message     String
  isRead      Boolean @default(false)

  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}


model Goal {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      GoalStatus @default(PENDING)

  ownerId     String
  workspaceId String

  owner       User      @relation("GoalOwner", fields: [ownerId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actionItems ActionItem[]

  milestones  Milestone[]
  activities  GoalActivity[]

  dueDate     DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Milestone {
  id        String @id @default(uuid())
  title     String
  progress  Int @default(0)

  goalId    String
  goal      Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model GoalActivity {
  id        String @id @default(uuid())

  message   String
  type      String

  goalId    String
  userId    String

  goal      Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Announcement {
  id          String   @id @default(uuid())

  title       String
  content     String
  isPinned    Boolean  @default(false)

  workspaceId String
  authorId    String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])

  reactions   Reaction[]
  comments    Comment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reaction {
  id              String @id @default(uuid())

  emoji           String

  announcementId  String
  userId          String

  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())

  @@unique([announcementId, userId])
}

model Comment {
  id              String @id @default(uuid())

  content         String

  announcementId  String
  userId          String

  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
}

model ActionItem {
  id          String   @id @default(uuid())

  title       String
  description String?

  status      ActionStatus   @default(TODO)
  priority    ActionPriority @default(MEDIUM)

  dueDate     DateTime?

  goalId      String?
  workspaceId String
  assigneeId  String

  goal        Goal?     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee    User      @relation(fields: [assigneeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
