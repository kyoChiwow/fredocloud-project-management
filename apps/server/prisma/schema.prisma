generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  super_admin
  user
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  avatarUrl     String?
  role          SystemRole @default(user)
  isDeleted     Boolean    @default(false)
  
  workspaces    WorkspaceMember[]
  goals         Goal[]    @relation("GoalOwner")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Workspace {
  id          String    @id @default(uuid())
  name        String
  description String?
  accentColor String    @default("#4F46E5")
  members     WorkspaceMember[]
  goals       Goal[]
  createdAt   DateTime  @default(now())
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  role        Role      @default(MEMBER)
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

enum Role {
  ADMIN
  MEMBER
}

model Goal {
  id          String    @id @default(uuid())
  title       String
  status      String    @default("TODO") // TODO, IN_PROGRESS, COMPLETED
  dueDate     DateTime?
  ownerId     String
  workspaceId String
  owner       User      @relation("GoalOwner", fields: [ownerId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}
